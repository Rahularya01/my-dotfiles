    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "space shift+s",
    "command": "workbench.action.replaceInFiles",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "space s p",
