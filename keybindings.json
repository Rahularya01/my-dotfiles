    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "space c a",
    "command": "editor.action.codeAction",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "space o i",
    "command": "editor.action.sourceAction",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "[ d",
