{
  "[css]": {
    "editor.tabSize": 2,
  },
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[html]": {
    "editor.tabSize": 2,
  },
  "[javascript]": {
    "editor.tabSize": 2,
  },
  "[javascriptreact]": {
    "editor.tabSize": 2,
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
  },
  "[typescript]": {
    "editor.tabSize": 2,
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
  },
  "auto-close-tag.activationOnLanguage": [
    "html",
    "javascriptreact",
    "typescriptreact",
  ],
  "breadcrumbs.enabled": false,
  "breadcrumbs.icons": false,
  "breadcrumbs.symbolPath": "off",
  "chat.editing.confirmEditRequestRetry": false,
  "chat.tools.terminal.autoApprove": {
    "git checkout": true,
    "npm run analyze": true,
    "npx": true,
  },
  "cSpell.overviewRulerColor": "",
  "cSpell.spellCheckDelayMs": 350,
  "cSpell.suggestionsTimeout": 500,
  "cSpell.textDecorationColor": "lightblue",
  "cSpell.userWords": ["firestore", "Tokenomics"],
  "debug.javascript.autoAttachFilter": "onlyWithFlag",
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {},
  "editor.codeLens": false,
  "editor.cursorBlinking": "solid",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fastScrollSensitivity": 4,
  "editor.folding": true,
  "editor.fontFamily": "CaskaydiaCove Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.glyphMargin": true,
  "editor.hideCursorInOverviewRuler": true,
  "editor.hover.delay": 10000,
  "editor.hover.enabled": "off",
  "editor.lightbulb.enabled": "off",
  "editor.lineDecorationsWidth": 10,
  "editor.lineNumbers": "relative",
  "editor.lineNumbersMinChars": 3,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.parameterHints.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 12,
  "editor.showFoldingControls": "mouseover",
  "editor.stickyScroll.enabled": false,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "italic font",
        "scope": [
          "comment",
          "keyword",
          "storage",
          "keyword.control",
          "keyword.control.from",
          "keyword.control.flow",
          "keyword.operator.new",
          "keyword.control.import",
          "keyword.control.export",
          "keyword.control.default",
          "keyword.control.trycatch",
          "keyword.control.conditional",
          "storage.type",
          "storage.type.class",
          "storage.modifier.tsx",
          "storage.type.function",
          "storage.modifier.async",
          "variable.language",
          "variable.language.this",
          "variable.language.super",
          "meta.class",
          "meta.var.expr",
          "constant.language.null",
          "support.type.primitive",
          "entity.name.method.js",
          "entity.other.attribute-name",
          "punctuation.definition.comment",
          "text.html.basic entity.other.attribute-name",
          "tag.decorator.js entity.name.tag.js",
          "tag.decorator.js punctuation.definition.tag.js",
          "source.js constant.other.object.key.js string.unquoted.label.js",
        ],
        "settings": {
          "fontStyle": "italic",
        },
      },
    ],
  },
  "errorLens.enabled": true,
  "errorLens.followCursor": "allLinesExceptActive",
  "errorLens.messageEnabled": true,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1,
  },
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "off",
  "files.exclude": {
    "**/._*": true,
    "**/.DS_Store": true,
  },
  "git.autofetch": true,
  "git.autoStash": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.codeLens.enabled": false,
  "gitlens.defaultGravatarsStyle": "retro",
  "gitlens.plusFeatures.enabled": false,
  "gitlens.showWhatsNewAfterUpgrades": false,
  "glassit.alpha": 243,
  "glassit.step": 0,
  "javascript.preferences.includePackageJsonAutoImports": "off",
  "javascript.preferGoToSourceDefinition": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "material-icon-theme.hidesExplorerArrows": false,
  "problems.autoReveal": false,
  "problems.decorations.enabled": true,
  "problems.showCurrentInStatus": false,
  "problems.sortOrder": "position",
  "rust-analyzer.diagnostics.enable": true,
  "rust-analyzer.diagnostics.experimental.enable": true,
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.check.command": "clippy",
  "search.exclude": {
    "**/._*": true,
    "**/.DS_Store": true,
  },
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.untrustedFiles": "open",
  "settingsSync.keybindingsPerPlatform": false,
  "supermaven.enableJumpSuggestions": false,
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
  ],
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.commandsToSkipShell": ["workbench.action.closePanel"],
  "terminal.integrated.confirmOnKill": "always",
  "terminal.integrated.defaultLocation": "view",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.env.windows": {
    "PATH": "${env:PATH};${workspaceRoot}\\node_modules\\.bin;${env:PNPM_HOME}",
  },
  "terminal.integrated.fontFamily": "CaskaydiaCove Nerd Font",
  "terminal.integrated.fontSize": 14.5,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "icon": "terminal-powershell",
      "path": "pwsh",
    },
  },
  "terminal.integrated.scrollback": 5000,
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "typescript.preferGoToSourceDefinition": true,
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vim.easymotion": true,
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-space>": false,
    "<C-Space>": false,
    "f": true,
    "F": true,
    "t": false,
    "T": true,
  },
  "vim.highlightedyank.enable": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "after": ["<Esc>"],
      "before": ["j", "k"],
    },
  ],
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["]", "d"],
      "commands": ["editor.action.marker.next"],
      "silent": true,
    },
    {
      "before": ["[", "d"],
      "commands": ["editor.action.marker.prev"],
      "silent": true,
    },
    {
      "before": ["<Esc>"],
      "commands": [":nohl"],
      "silent": true,
    },
    {
      "before": ["g", "D"],
      "commands": ["editor.action.revealDeclaration"],
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"],
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.referenceSearch.trigger"],
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"],
    },
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"],
    },
    {
      "before": ["g", "y"],
      "commands": ["editor.action.goToTypeDefinition"],
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"],
    },
    {
      "before": ["g", "l"],
      "commands": ["editor.action.showHover"],
    },
  ],
  "vim.searchHighlightColor": "#f6ff0080",
  "vim.searchHighlightTextColor": "#fff",
  "vim.smartRelativeLine": false,
  "vim.surround": true,
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,
  "window.commandCenter": false,
  "window.density.editorTabHeight": "compact",
  "window.menuBarVisibility": "toggle",
  "window.systemColorTheme": "dark",
  "window.title": " ",
  "workbench.colorCustomizations": {
    "statusBar.background": "#3c3836",
    "statusBar.noFolderBackground": "#3c3836",
    "statusBar.debuggingBackground": "#3c3836",
    "statusBar.foreground": "#ffffff",
    "statusBar.debuggingForeground": "#ffffff",
  },
  "workbench.colorTheme": "Gruvbox Dark Hard",
  "workbench.editor.decorations.badges": true,
  "workbench.editor.decorations.colors": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.tabActionCloseVisibility": true,
  "workbench.editor.tabActionLocation": "right",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.panel.opensMaximized": "never",
  "workbench.sideBar.location": "left",
  "workbench.secondarySideBar.defaultVisibility": "visibleInWorkspace",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.indent": 12,
  "workbench.view.alwaysShowHeaderActions": false,
  "zenMode.fullScreen": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,
  "terminal.external.linuxExec": "/usr/bin/ghostty",
  "inlineChat.enableV2": true,
  "terminal.external.osxExec": "Ghostty.app",
  "terminal.explorerKind": "external",
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "cursor.cpp.disabledLanguages": ["plaintext", "markdown", "scminput"],
  "workbench.activityBar.orientation": "vertical",
}
